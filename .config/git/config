[alias]
    c = commit -m
    amend = commit --amend
    g = grep --break --heading --line-number
    lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)' --all
    ls = ls-files
    s = status
    sup = !git submodule sync && git submodule update --init
    tree = log --graph --pretty=format:'%C(auto)%h - %s [%an] (%C(blue)%ar)%C(auto)%d'
    untrack = update-index --skip-worktree
    retrack = update-index --no-skip-worktree
    untracked = !git ls-files -v | grep '^S'
    zip = archive -o latest.zip HEAD

[apply]
  whitespace = fix

[branch]
    autosetupmerge = true

[color]
    diff = auto
    status = auto
    branch = auto
    ui = true

[color "grep"]
    filename = 5
    linenumber = 2

[core]
    abbrev = 12
    autocrlf = input
    editor = subl -w
    excludesfile = ~/.config/git/ignore
    pager = diff-so-fancy | less --tabs=4 -RFX # apt install diff-so-fancy | brew install diff-so-fancy
    whitespace = fix,space-before-tab,tab-in-indent,trailing-space

[credential]
    helper = osxkeychain

[diff]
    algorithm = histogram

[format]
    pretty = format:%C(blue)%ad%Creset %C(yellow)%h%C(green)%d%Creset %C(blue)%s %C(magenta) [%an]%Creset

[grep]
    lineNumber = true

[hub]
    protocol = https

[log]
    date = iso

[merge]
    # apt install meld | brew cask install meld
    tool = meld

[push]
    default = current

[rebase]
    autosquash = true

[rerere]
    enabled = true

[user]
    useConfigOnly = true

[submodule]
    fetchJobs = 4
