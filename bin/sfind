#!/usr/bin/env bash
set -o errexit
set -o pipefail
set -o nounset

# sfind = string-find

deps=0
for app in ripgrep fzf; do
    ! command -v ${app} &> /dev/null && echo "$app is not installed" && deps=1
done
[[ $deps -ne 0 ]] && exit 1

if command -v bat >/dev/null 2>&1; then
    rg "" --line-number . | fzf --delimiter ":" \
    --preview "bat --highlight-line {2} {1}" \
    --bind "change:reload:rg {q} --line-number . || true" \
    --bind "ctrl-c:execute(echo {1} | pbcopy)+abort" \
    --bind "ctrl-d:abort"
else
    rg "" --line-number . | fzf --delimiter ":" \
    --bind "change:reload:rg {q} --line-number . || true" \
    --bind "ctrl-o:execute(open -R {1})" \
    --bind "ctrl-e:execute(ccc {1})" \
    --bind "ctrl-x:execute(ooo {1})" \
    --bind "ctrl-d:abort"
fi
