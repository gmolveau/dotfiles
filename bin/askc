#!/usr/bin/env bash
set -o errexit
set -o pipefail
set -o nounset

# create a fresh working folder under a stable base and run claude there with edits allowed
# trust the base folder once (manually); subfolders inherit trust, so no prompt per run

base="${HOME}/.local/share/askclaude"
mkdir -p "${base}"

# --purge: remove all working folders under the base and exit
if [[ "${1:-}" == "--purge" ]]; then
	rm -rf "${base:?}"/askc.*
	echo "askc: purged all working folders under ${base}"
	exit 0
fi

# --name <session>: use a named working folder instead of a random one
if [[ "${1:-}" == "--name" ]]; then
	if [[ -z "${2:-}" ]]; then
		echo "askc: --name requires a session name" >&2
		exit 1
	fi
	workdir="${base}/${2}"
	mkdir -p "${workdir}"
	shift 2
else
	workdir=$(mktemp -d "${base}/askc.XXXXXX")
fi

echo "askc: working in ${workdir}"

cd "${workdir}"
exec claude --permission-mode acceptEdits "$@"
