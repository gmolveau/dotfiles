#!/usr/bin/env bash
set -o errexit
set -o pipefail
set -o nounset

# find a file by name (glob) in a specified directory or in cwd
# usage: f <name-or-glob> [dir]

if [ $# -eq 0 ]; then
    echo "usage: f <name-or-glob> [dir]"
    exit 1
fi

dir="${2:-.}"
if [ ! -d "${dir}" ]; then
    echo "${dir} is not a directory"
    exit 1
fi

find "${dir}" -name "${1}"
